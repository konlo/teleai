{
  "version": 1,
  "description": "Numbered chatbot quality scenarios for routing, planning, visualization, context, trace, and manual live checks.",
  "scenarios": [
    {
      "id": "ROUTE-001",
      "title": "새 사용자 입력은 일반 턴으로 처리한다",
      "suite": "route",
      "priority": "P0",
      "prompt": "balance를 시각화해줘",
      "executor": "routing_static",
      "table": "",
      "dataset": "",
      "expects": {
        "process": true,
        "query": "balance를 시각화해줘"
      },
      "artifacts": {},
      "tags": ["static", "routing"],
      "enabled": true
    },
    {
      "id": "PLAN-001",
      "title": "latitude/longitude 요청은 longitude histogram으로 퇴행하지 않는다",
      "suite": "plan",
      "priority": "P0",
      "prompt": "latitude X축 longitude Y축 scatter plot를 그려줘",
      "executor": "visual_self_eval",
      "table": "workspace.default.stormtrooper",
      "dataset": "",
      "case_name": "scatter_lat_lon",
      "expects": {
        "plot_type": "scatter",
        "x_column": "latitude",
        "y_column": "longitude",
        "sql_contains": ["longitude", "latitude"],
        "figure_required": true
      },
      "artifacts": {},
      "tags": ["static", "visual", "regression"],
      "enabled": true
    },
    {
      "id": "VIZ-001",
      "title": "실제 CSV numeric histogram",
      "suite": "visual",
      "priority": "P0",
      "prompt": "pressure_altitude 분포를 histogram으로 그려줘",
      "executor": "visual_chat_e2e",
      "table": "workspace.default.stormtrooper",
      "dataset": "/Users/najongseong/dataset/stormtrooper.csv",
      "expects": {
        "plot_type": "histogram",
        "column": "pressure_altitude",
        "sql_contains": ["pressure_altitude"],
        "df_columns": ["pressure_altitude"],
        "trace_events": ["controlled_plan", "controlled_reload_sql", "sql_execution", "visualization_config", "controlled_result"],
        "figure_required": true
      },
      "artifacts": {
        "figure_dir": "/tmp/teleai_visual_chat_e2e"
      },
      "tags": ["e2e", "visual", "csv"],
      "enabled": true
    },
    {
      "id": "VIZ-002",
      "title": "datetime X축 numeric Y축 line chart",
