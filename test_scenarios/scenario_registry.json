      "executor": "visual_self_eval",
      "table": "workspace.default.visual_fixture",
      "dataset": "",
      "case_name": "correlation_heatmap",
      "expects": {
        "plot_type": "heatmap",
        "columns": ["metric_a", "metric_b", "metric_c"],
        "aggregation": "correlation",
        "figure_required": true
      },
      "artifacts": {},
      "tags": ["static", "visual"],
      "enabled": true
    },
    {
      "id": "VIZ-004",
