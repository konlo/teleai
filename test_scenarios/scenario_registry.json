      "dataset": "",
      "case_name": "pivot_heatmap",
      "expects": {
        "plot_type": "heatmap",
        "x_column": "category",
        "y_column": "segment",
        "value_column": "amount",
        "sql_contains": ["AVG(amount) AS stat_value", "GROUP BY category, segment"],
        "figure_required": true
      },
      "artifacts": {},
      "tags": ["static", "visual"],
      "enabled": true
    },
